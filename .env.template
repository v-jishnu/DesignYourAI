# ==============================================================================
# LLM PROVIDER CONFIGURATION
# ==============================================================================

# Choose your LLM provider (gemini, anthropic, openai, groq, together)
LLM_PROVIDER=gemini

# ==============================================================================
# API KEYS - Add the key for your chosen provider
# ==============================================================================

# Google Gemini (FREE TIER - RECOMMENDED)
# Get your key: https://makersuite.google.com/app/apikey
# Free tier: 15 requests/min, 1500 requests/day
GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude (PAID)
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (PAID)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq (FREE TIER)
# Get your key: https://console.groq.com/
GROQ_API_KEY=

# Together.ai (FREE TIER)
# Get your key: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# ==============================================================================
# PLATFORM-SPECIFIC TOKENS
# ==============================================================================

# StrataScratch (for extracting technical interview questions)
# Get your token: Login to platform.stratascratch.com, open DevTools > Network tab,
# find a graphql/ request, and copy the Authorization header value (after "Token ")
STRATASCRATCH_TOKEN=

# ==============================================================================
# OPTIONAL SETTINGS
# ==============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Similarity threshold for deduplication (0.0 to 1.0)
SIMILARITY_THRESHOLD=0.85
